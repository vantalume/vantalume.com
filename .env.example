# Public canonical origin, without a trailing slash
NEXT_PUBLIC_SITE_URL=https://vantalume.com

# Contact delivery. Create at https://resend.com and verify the sending domain.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=Vantalume <contact@vantalume.com>

# Required for concierge lead persistence in Hostinger MySQL.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Optional privacy-conscious analytics (disabled until configured and consented)
NEXT_PUBLIC_ANALYTICS_ENABLED=false
